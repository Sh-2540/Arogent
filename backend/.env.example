# Copy this file to .env and fill in real values before running the backend.
# Values shown here (except SECRET_KEY) are the same as the defaults baked
# into app/config.py — .env only needs to override what you actually want
# to change.

# --- Security (REQUIRED before any non-local deployment) ---
# Generate a real value with: python -c "import secrets; print(secrets.token_hex(32))"
# If left unset, the app falls back to a well-known development default and
# logs a loud warning at startup — JWTs signed with that default can be
# forged by anyone who has read this codebase.
SECRET_KEY=

# --- Database ---
# SQLite is fine for the hackathon MVP. For production, point this at a
# real Postgres/MySQL instance instead (see docs/DEPLOYMENT.md).
DATABASE_URL=sqlite:///./arogent.db

# --- CORS ---
# JSON array of allowed frontend origins. Must include your deployed
# frontend's exact URL (scheme + host + port) once deployed.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Token lifetime ---
ACCESS_TOKEN_EXPIRE_MINUTES=720

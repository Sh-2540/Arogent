# Copy this file to .env and fill in real values before building for
# deployment. Not required for local development — the app falls back to
# http://127.0.0.1:8000/api/v1 automatically if this is unset.

# The deployed backend's API base URL, including the /api/v1 prefix.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
